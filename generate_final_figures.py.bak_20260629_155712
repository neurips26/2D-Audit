                f"  \\centering\n"
                f"  \\includegraphics[width=\\linewidth]{{figs/{fname}.pdf}}\n"
                f"  \\caption{{{caption}}}\n"
                f"  \\label{{{label}}}\n"
                f"\\end{{figure}}"
            )

