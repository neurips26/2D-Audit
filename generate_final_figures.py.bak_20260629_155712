# FIGURE 1 — Scatter: Forget Rate vs LB-CKA
# ══════════════════════════════════════════════════════════════════════════════

def figure1():
    print("\n=== FIGURE 1: Scatter Forget Rate vs LB-CKA ===")

    fig, ax = plt.subplots(figsize=(3.3, 2.6))

    for method, fr, ra, lb in LLAVA_SCATTER:
        color  = METHOD_COLOR.get(method, "#333333")
        marker = METHOD_MARKER.get(method, "o")
        ms     = 7 if method != "No Unlearn" else 6
        zorder = 4 if method == "GradDiff" else 3
        ax.scatter(fr, lb, color=color, marker=marker, s=ms**2,
                   zorder=zorder, edgecolors="black", linewidths=0.4)

    # Reference lines from No Unlearn
    nu_fr = 0.0250; nu_lb = 1.0000
    ax.axvline(nu_fr, color="#888888", linewidth=0.6, linestyle="--",
               alpha=0.6, zorder=1)
    ax.axhline(nu_lb, color="#888888", linewidth=0.6, linestyle="--",
               alpha=0.6, zorder=1)

    # Annotations — nudge to avoid overlap
    offsets = {
        "No Unlearn":  (-48, -28),
        "NPO":         (-8, 17),
        "MMUnlearner": (8, -16),
        "CAGUL":       (22, 18),
        "SineProject": (-62, 27),
        "GradDiff":    (8, 5),
    }
    for method, fr, ra, lb in LLAVA_SCATTER:
        dx, dy = offsets.get(method, (6, 6))
        ax.annotate(
            method,
            xy=(fr, lb),
            xytext=(dx, dy),
            textcoords="offset points",
            fontsize=FONT_SMALL,
            color=METHOD_COLOR.get(method, "#333333"),
            ha="left",
            va="center",
            annotation_clip=False,
        )

    ax.set_xlabel("Forget rate", fontsize=FONT_MED)
    ax.set_ylabel("Language-backbone CKA", fontsize=FONT_MED)
    ax.set_xlim(0.015, 0.085)
    ax.set_ylim(0.82, 1.01)
    ax.set_xticks([0.025, 0.050, 0.075])
    ax.set_xticklabels(["0.025", "0.050", "0.075"])
    ax.set_title(
        "LLaVA-1.5-7B ? mllmu_real",
        fontsize=FONT_MED,
        pad=3,
    )
    ax.spines["top"].set_visible(False)
    ax.spines["right"].set_visible(False)

    # Highlight: same FR, different LB
    ax.annotate("", xy=(0.025, 0.9336), xytext=(0.025, 0.9980),
                arrowprops=dict(arrowstyle="<->", color="#D6604D",
                                lw=0.8, linestyle="dashed"))
    ax.text(
        0.027,
        0.965,
        "same forget rate,\ndifferent geometry",
        fontsize=FONT_SMALL,
        color="#444444",
        va="center",
    )

    fig.tight_layout(pad=0.4)
    savefig(fig, "fig1_scatter_fr_lb")


