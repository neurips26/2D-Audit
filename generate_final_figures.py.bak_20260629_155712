def chk(label, verdict, detail=""):
    CHECKS.append({"check":label,"verdict":verdict,"detail":str(detail)})
    icon = {"PASS":"OK","WARN":"!!","FAIL":"XX"}.get(verdict,"??")
    print(f"  [{icon} {verdict}] {label}: {detail}")
    return verdict == "PASS"


